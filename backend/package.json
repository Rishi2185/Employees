{
  "name": "aarvy-hospital-backend",
  "version": "1.0.0",
  "description": "Backend API for the Aarvy hospital-side system (Doctors, Appointments, Daily Summaries) — pairs with the Aarvy patient app and powers the reception desktop + admin mobile apps.",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seed/seed.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "lint": "eslint src"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "imagekit": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.5.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./test/globalSetup.js",
    "globalTeardown": "./test/globalTeardown.js",
    "setupFilesAfterEnv": [
      "./test/setup.js"
    ],
    "testTimeout": 30000
  }
}
